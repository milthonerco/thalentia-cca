---
const links = [
  { name: 'Mr.Mascadedo TECH', href: '/categories/mr-mascadedo-tech' },
  { name: 'Granny hall', href: '/categories/granny-hall' },
  { name: 'ArtFestival', href: '/categories/art-festival' },
  { name: 'Stars Cup', href: '/categories/stars-cup' },
  { name: 'Contact', href: '/contact' },
];
---
<nav
  id="mainNavbar"
  class="fixed top-0 left-0 w-full bg-transparent text-[#FFFCFB] px-4 py-6 z-20 drop-shadow-[0_0_10px_black]"
>
  <div class="flex items-center justify-center">
    <ul class="flex flex-wrap justify-center gap-x-4 gap-y-2 uppercase font-bold tracking-wide text-center">
      {links.map(link => (
        <li>
          <a href={link.href} class="hover:text-[#9B177E] text-xs sm:text-sm md:text-lg lg:text-xl xl:text-2xl">
            {link.name}
          </a>
        </li>
      ))}
    </ul>
  </div>
</nav>

