---

<section
  id="scrollShowcase"
  class="relative w-screen h-screen overflow-hidden "
>
  <div
    id="blurredBg"
    class="absolute inset-0 bg-center bg-cover filter blur-2xl opacity-100 transition-all duration-500 z-0"
  >
  </div>

  <div
    id="scrollContainer"
    class="relative w-full h-full flex items-center justify-center"
  >
    {
      images.map((img, index) => (
        <div class="scroll-item absolute text-center" data-index={index}>
          <a href={img.link} class="group block">
            <h2 class="text-[#ebe5c2] text-xl mb-2 font-bold drop-shadow-[0_0_10px_black]">{img.name}</h2>
            <div class="relative inline-block">
              <img
                src={img.src}
                alt={img.name}
                class="w-[300px] lg:w-[400px] xl:w-[500px] h-auto mx-auto"
              />
              <span
                class="absolute bottom-2 left-1/2 -translate-x-1/2 bg-black/60 text-white text-base px-3 py-1 rounded transition-opacity duration-200 group-hover:opacity-100 opacity-80"
              >
                + más
              </span>
            </div>
          </a>
        </div>
      ))
    }
  </div>
</section>

<style>
  .scroll-item {
    transition:
      transform 0.2s ease,
      opacity 0.3s ease;
    will-change: transform, opacity;
  }

  .scroll-img {
    width: 400px;
  }

  .scroll-text {
    transition:
      transform 0.3s,
      opacity 0.3s;
  }
</style>

<script>
  import { initScrollShowcase } from "../scripts/secondSectionScroll.js";

  document.addEventListener("DOMContentLoaded", () => {
    initScrollShowcase();
  });
</script>
