---
import Layout from "../layouts/Layout.astro";

const { itemsInCategory, categoryInfo, activeItemSlug } = Astro.props;

type Item = (typeof itemsInCategory)[number];
const firstItem =
  itemsInCategory.find((item: Item) => item.slug === activeItemSlug)?.data ??
  itemsInCategory[0].data;
---

<>
  <div class="w-full flex justify-center items-center mb-10 pt-10">
    <a href="/">
      <img
        src="/LogoPequeno.png"
        alt="Logo"
        class="w-full max-w-[250px] h-auto"
      />
    </a>
  </div>

  <div
    class="flex flex-col lg:flex-row gap-6 mt-12 md:mt-16 lg:mt-20 px-4 md:px-8 justify-center"
  >
    <div class="flex-1 max-w-xl mx-auto lg:mx-0">
      <img
        id="selected-image"
        src={firstItem.image}
        alt={firstItem.title}
        class="w-full rounded shadow-md object-cover transition-opacity duration-500 ease-in-out opacity-100"
      />
    </div>
    <div class="flex-1 max-w-xl mx-auto lg:mx-0">
      <h1
        id="selected-title"
        class="italic font-bold text-4xl text-[#507687] mb-2"
      >
        {firstItem.title}
      </h1>
      <p id="selected-description" class="text-[#507687] text-base mb-4">
        {firstItem.description}
      </p>
      <h3 id="selected-edad" class="italic text-base text-[#507687] mb-2">
        {firstItem.edad}
      </h3>
      <h3 id="selected-lugar" class="italic text-base text-[#507687] mb-2">
        {firstItem.lugar}
      </h3>
      <h3 id="selected-horario" class="italic text-base text-[#507687] mb-4">
        {firstItem.horario}
      </h3>

      <div class="mt-4">
        <a
          href="https://forms.gle/KJR2ycg1ShyFmipx8"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block px-6 py-3 bg-[#507687] text-white font-semibold rounded-lg shadow hover:bg-orange-600 transition-colors duration-300 text-center w-full md:w-auto"
        >
          Inscribirse
        </a>
      </div>
    </div>

    <div
      class="flex overflow-x-auto lg:overflow-x-hidden lg:flex-col gap-2 mt-4 lg:mt-0 mx-auto lg:mx-0"
    >
      {
        itemsInCategory.map((item: Item) => (
          <button
            type="button"
            data-title={item.data.title}
            data-description={item.data.description}
            data-image={item.data.image}
            data-link={`/categories/${item.data.category}/${item.slug}`}
            aria-label={`Cambiar a ${item.data.title}`}
            class="focus:outline-none"
          >
            <img
              src={item.data.image}
              alt={item.data.title}
              class="rounded shadow hover:ring-2 hover:ring-orange-500 transition-all duration-300 ease-in-out w-20 h-20 md:w-24 md:h-24 object-cover pt-1000"
            />
          </button>
        ))
      }
    </div>
  </div>

  <script is:inline>
    const titleEl = document.getElementById("selected-title");
    const descEl = document.getElementById("selected-description");
    const imageEl = document.getElementById("selected-image");
    const buttons = document.querySelectorAll("button");

    function updateContent({ title, description, image, link }) {
      titleEl.textContent =  title;
      descEl.textContent = description;

      imageEl.classList.add("opacity-0");
      setTimeout(() => {
        imageEl.src = image;
        imageEl.alt = title;
        imageEl.classList.remove("opacity-0");
      }, 200);

      window.history.pushState({}, "", link);
    }

    buttons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const { title, description, image, link } = btn.dataset;
        updateContent({ title, description, image, link });
      });
    });
  </script>
</>
