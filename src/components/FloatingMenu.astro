---

---

<div
  id="floatingMenu"
  class="fixed bottom-4 left-1/2 transform -translate-x-1/2 z-50 hidden "
>
  <div
    id="listButton"
    class="flex rounded-md overflow-hidden shadow-lg cursor-pointer"
  >
    <div class="bg-white p-2 flex items-center justify-center">
      <svg
        class=" w-6 h-6 text-[#507687]"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
    </div>
    <div
      class="bg-[#edebea] text-[#507687]  text-base font-bold px-3 flex items-center justify-center"
    >
      LIST
    </div>
  </div>
  <div
    id="closeButton"
    class="hidden rounded-md overflow-hidden shadow-lg cursor-pointer"
  >
    <div class="bg-[#FFFCFB] p-2 flex items-center justify-center text-xl">X</div>
    <div
      class="bg-[#507687] text-[#FFFCFB] font-bold px-3 flex text-xl items-center justify-center"
    >
      CLOSE
    </div>
  </div>
</div>

<div
  id="fullscreenMenu"
  class="fixed font-horta inset-0 bg-[#FFFCFB] flex flex-col items-center justify-center z-40 opacity-0 scale-95 pointer-events-none transition-all duration-500"
>
  <img
    id="previewImage"
    src="/imgScroll/1.png"
    alt="Preview"
    class="absolute inset-0 w-full h-full object-cover opacity-20 transition-all duration-500"
  />

  <nav
    class=" font-mifuente relative flex flex-col md:flex-row items-center justify-center space-y-4 md:space-y-0 md:space-x-8 text-center text-[#507687] text-4xl  z-10"
  >
    <a href="/categories/mr-mascadedo-tech"  data-image="/imgScroll/17.png">Economía y Finanzas</a>
    <a href="/categories/granny-hall" data-image="/imgScroll/3.png">Granny hall</a>
    <a href="/categories/art-festival" data-image="/imgScroll/5.png">ArtFestival</a>
    <a href="/categories/stars-cup" data-image="/imgScroll/9.png">Stars Cup</a>
  </nav>
</div>

<script type="module">
  const listBtn = document.getElementById("listButton");
  const closeBtn = document.getElementById("closeButton");
  const fullscreenMenu = document.getElementById("fullscreenMenu");

  if (listBtn && closeBtn && fullscreenMenu) {
    listBtn.addEventListener("click", () => {
      fullscreenMenu.classList.remove(
        "opacity-0",
        "scale-95",
        "pointer-events-none"
      );
      fullscreenMenu.classList.add(
        "opacity-100",
        "scale-100",
        "pointer-events-auto"
      );
      listBtn.classList.add("hidden");
      closeBtn.classList.remove("hidden");
    });

    closeBtn.addEventListener("click", () => {
      fullscreenMenu.classList.remove(
        "opacity-100",
        "scale-100",
        "pointer-events-auto"
      );
      fullscreenMenu.classList.add(
        "opacity-0",
        "scale-95",
        "pointer-events-none"
      );
      closeBtn.classList.add("hidden");
      listBtn.classList.remove("hidden");
    });
  }
  const previewImg = document.getElementById("previewImage");
  const links = document.querySelectorAll("nav a");

  const images = Array.from(links)
    .map((link) => link.getAttribute("data-image"))
    .filter((src) => src !== null);

  // Desktop: hover cambia la imagen
  links.forEach((link) => {
    link.addEventListener("mouseenter", () => {
      const newImage = link.getAttribute("data-image");
      if (newImage && previewImg instanceof HTMLImageElement) {
        previewImg.src = newImage;
      }
    });
  });

  // Móvil: loop automático
  let currentIndex = 0;
  setInterval(() => {
    if (window.innerWidth < 768 && previewImg instanceof HTMLImageElement) {
      previewImg.src = images[currentIndex];
      currentIndex = (currentIndex + 1) % images.length;
    }
  }, 3000); // Cambia cada 3 segundos (ajústalo como quieras)
</script>
