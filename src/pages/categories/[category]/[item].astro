---
import { getCollection } from "astro:content";
import CategoryWithGallery from "../../../components/CategoryWithGallery.astro";
import FloatingMenu from "../../../components/FloatingMenu.astro";
import Layout from "../../../layouts/Layout.astro";

export const prerender = true; // ← AGREGA ESTO

export async function getStaticPaths() {
  const items = await getCollection("items");

  return items.map((item) => ({
    params: {
      category: item.data.category,
      item: item.id,
    },
    props: { item }, // Pasar el item como prop
  }));
}

const { category } = Astro.params;
const { item: currentItem } = Astro.props;

const itemsAll = await getCollection("items");
const itemsInCategory = itemsAll.filter(
  (i) => i.data.category === category
);

const categoryDescription = currentItem.data.description ?? "";

const categoryTitle = category
  .replace(/-/g, " ")
  .replace(/\b\w/g, c => c.toUpperCase());
---

<html>
  <body>
    <Layout>
      <main class="pb-20">
        <CategoryWithGallery
          itemsInCategory={itemsInCategory}
          categoryInfo={{
            title: categoryTitle,
            description: categoryDescription,
          }}
          activeItemSlug={currentItem.id}
        />
      </main>
      <FloatingMenu />
    </Layout>
  </body>
</html>