---
export const prerender = false;
---

<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Dashboard</title>
</head>

<body class="bg-[#f6f7fb] m-0 p-4 font-sans">

<div class="max-w-[1100px] mx-auto flex flex-col gap-4">

    <div class="bg-white rounded-2xl p-3.5 flex items-center justify-between gap-3 flex-wrap">
        <div id="usuario" class="flex items-center gap-3 min-w-[200px]">
            <span class="text-sm text-gray-500">Cargando usuario...</span>
        </div>

        <div class="actions flex gap-2 flex-wrap">
            <a href="/" class="px-3 py-2 rounded-xl bg-[#111] text-white text-xs inline-flex items-center justify-center no-underline hover:bg-black transition-colors">
                🏠 Home
            </a>
            <button id="logout" class="px-3 py-2 rounded-xl bg-red-600 text-white text-xs items-center justify-center hidden hover:bg-red-700 transition-colors">
                Cerrar sesión
            </button>
        </div>
    </div>

    <div class="bg-white rounded-2xl p-4 shadow-sm">
        <h2 class="text-base font-bold m-0 mb-3 text-gray-800">Mis academias</h2>
        <p id="contador" class="text-sm text-gray-600 mb-3"></p>
        <div id="misAcademias" class="grid grid-cols-2 md:grid-cols-3 gap-3"></div>
    </div>

    <div class="bg-white rounded-2xl p-4 shadow-sm">
        <h2 class="text-base font-bold m-0 mb-3 text-gray-800">Academias disponibles</h2>
        <div id="academias" class="grid grid-cols-2 md:grid-cols-3 gap-3"></div>
    </div>

</div>

<script>
    import "../scripts/dashboard.js";
</script>

</body>
</html>