---
export const prerender = false;
---

<html lang="es">
    <head>
        <meta charset="UTF-8" />

        <meta name="viewport" content="width=device-width, initial-scale=1" />

        <title>Dashboard</title>

        <style>
            body {
                font-family: ui-sans-serif, system-ui;
                background: #f5f6f8;
                margin: 0;
                padding: 24px;
            }

            .container {
                max-width: 1100px;
                margin: auto;
                display: flex;
                flex-direction: column;
                gap: 18px;
            }

            .topbar {
                display: flex;
                justify-content: space-between;
                align-items: center;
                padding: 20px;
                background: white;
                border-radius: 18px;
            }

            .user {
                display: flex;
                gap: 14px;
                align-items: center;
            }

            .user img {
                width: 60px;
                height: 60px;
                border-radius: 50%;
                object-fit: cover;
            }

            .card {
                background: white;
                padding: 22px;
                border-radius: 18px;
            }

            .grid {
                display: grid;
                grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
                gap: 16px;
            }

            .academy {
                padding: 18px;
                border-radius: 16px;
                background: #fff;
                text-decoration: none;
                color: black;
                box-shadow: 0 0 8px rgba(0, 0, 0, 0.05);
            }

            .badge {
                padding: 4px 10px;
                background: #eee;
                border-radius: 999px;
                font-size: 12px;
            }

            .academy-footer {
                display: flex;
                justify-content: space-between;
                margin-top: 14px;
            }

            .verde {
                color: green;
                font-weight: bold;
            }

            .rojo {
                color: red;
                font-weight: bold;
            }

            .btn {
                padding: 10px 14px;
                border: none;
                border-radius: 10px;
                cursor: pointer;
            }

            .btn-logout {
                background: #dc2626;
                color: white;
            }
        </style>
    </head>

    <body>
        <div class="container">
            <div class="topbar">
                <div id="usuario" class="user">Cargando...</div>

                <div style="display:flex;gap:10px;">
                    <a
                        href="/"
                        class="btn"
                        style="
background:black;
color:white;
text-decoration:none;
"
                    >
                        🏠 Home
                    </a>

                    <button
                        id="logout"
                        class="btn btn-logout"
                        style="display:none"
                    >
                        Cerrar sesión
                    </button>
                </div>
            </div>

            <div class="card">
                <h2>Mis academias</h2>

                <p id="contador"></p>

                <div id="misAcademias" class="grid"></div>
            </div>

            <div class="card">
                <h2>Academias disponibles</h2>

                <div id="academias" class="grid"></div>
            </div>
        </div>

        <script>
            import "../scripts/dashboard.js";
        </script>
    </body>
</html>
