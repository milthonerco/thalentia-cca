---
export const prerender = false;
---

<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Admin Dashboard</title>
</head>

<body id="admin-body" class="bg-gradient-to-br from-slate-50 to-slate-100 min-h-screen opacity-0 transition-opacity duration-200">

<div class="max-w-7xl mx-auto px-4 py-8">

    <div class="bg-white rounded-lg shadow-sm p-6 mb-8 flex justify-between items-center text-black">
        <div class="flex items-center gap-4">
            <img 
                id="admin-avatar"
                src="https://ui-avatars.com/api/?name=Admin" 
                alt="Avatar"
                class="w-12 h-12 rounded-full border border-gray-200 object-cover"
            />
            <div>
                <h1 id="admin-name" class="text-lg font-semibold text-gray-900">Cargando Administrador...</h1>
                <p id="admin-email" class="text-sm text-gray-500">Verificando credenciales...</p>
            </div>
        </div>

        <div class="flex gap-3">
            <a href="/" class="px-4 py-2 rounded-lg bg-gray-900 text-white hover:bg-gray-800 transition font-medium text-sm flex items-center gap-1">
              Premio Home
            </a>
            <button 
                id="logout" 
                class="px-4 py-2 rounded-lg bg-red-600 text-white hover:bg-red-700 transition font-medium text-sm"
            >
                Cerrar sesión
            </button>
        </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8 text-black">
        <div class="bg-white rounded-lg shadow-sm p-6 border-l-4 border-blue-500">
            <p class="text-gray-600 text-sm font-medium mb-2">Total de academias</p>
            <p class="text-4xl font-bold text-gray-900" id="total-academias">0</p>
            <p class="text-xs text-gray-500 mt-2">Activas e inactivas</p>
        </div>

        <div class="bg-white rounded-lg shadow-sm p-6 border-l-4 border-green-500">
            <p class="text-gray-600 text-sm font-medium mb-2">Estudiantes activos</p>
            <p class="text-4xl font-bold text-gray-900" id="total-estudiantes">0</p>
            <p class="text-xs text-gray-500 mt-2">Inscritos actualmente</p>
        </div>

        <div class="bg-white rounded-lg shadow-sm p-6 border-l-4 border-amber-500">
            <p class="text-gray-600 text-sm font-medium mb-2">Academia popular</p>
            <p class="text-lg font-bold text-gray-900 truncate" id="popular-academia">-</p>
            <p class="text-xs text-gray-500 mt-2" id="popular-count">0 inscritos</p>
        </div>
    </div>

    <div class="bg-white rounded-lg shadow-sm p-6 mb-8 text-black">
        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-6">
            <h2 class="text-2xl font-bold text-gray-900">Gestión de academias</h2>
            <div class="flex w-full sm:w-auto items-center gap-3">
                <input 
                    type="text" 
                    id="search-academias"
                    placeholder="Buscar por categoría o nombre..." 
                    class="w-full sm:w-64 px-4 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
                />
                <button 
                    id="save-changes-btn"
                    class="px-4 py-2 bg-gray-400 text-white rounded-lg hover:bg-gray-500 transition font-medium text-sm whitespace-nowrap"
                >
                    Flujo Guardar Cambios
                </button>
            </div>
        </div>

        <div class="overflow-x-auto">
            <table class="w-full text-sm border-collapse">
                <thead class="bg-gray-50 border-b border-gray-200">
                    <tr class="text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">
                        <th class="px-6 py-3">Academia</th>
                        <th class="px-6 py-3">Categoría</th>
                        <th class="px-6 py-3 text-center">Inscritos</th>
                        <th class="px-6 py-3 text-center">Cupo máx</th>
                        <th class="px-6 py-3 text-center">Activa</th>
                        <th class="px-6 py-3 text-center">Inscripciones</th>
                        <th class="px-6 py-3 text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody id="academias-tbody" class="divide-y divide-gray-100">
                    <tr>
                        <td colspan="7" class="px-6 py-8 text-center text-gray-500">Cargando academias desde Supabase...</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <div class="bg-white rounded-lg shadow-sm p-6 text-black">
        <h2 class="text-2xl font-bold text-gray-900 mb-6">Reportes</h2>

        <div class="flex gap-3 mb-6">
            <button 
                id="export-csv"
                class="px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 transition font-medium text-sm"
            >
                📊 Exportar CSV
            </button>
            <button 
                id="refresh-reports"
                class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition font-medium text-sm"
            >
                🔄 Actualizar
            </button>
        </div>

        <div class="mb-8">
            <h3 class="text-lg font-semibold text-gray-900 mb-4">Inscritos por academia</h3>
            <div class="overflow-x-auto border border-gray-200 rounded-lg">
                <table class="w-full text-sm">
                    <thead class="bg-gray-50 border-b border-gray-200">
                        <tr class="text-xs font-semibold text-gray-600 uppercase tracking-wider">
                            <th class="px-6 py-3 text-left">Academia</th>
                            <th class="px-6 py-3 text-right">Inscritos</th>
                            <th class="px-6 py-3 text-right">% ocupación</th>
                        </tr>
                    </thead>
                    <tbody id="report-inscritos" class="divide-y divide-gray-100">
                        <tr>
                            <td colspan="3" class="px-6 py-8 text-center text-gray-500">Cargando análisis de ocupación...</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</div>

<script src="/src/scripts/adminGuard.ts"></script>
</body>
</html>